{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "module": "ESNext",
    "jsx": "react",
    "target": "es2017",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "ignoreDeprecations": "5.0",
    "skipLibCheck": true
  },
  "include": ["src"]
}
